<xs:element name="age" nillable="false" type="xs:integer" minOccurs="0" maxOccurs="1"/>
<xs:element name="homeAddress" nillable="true" type="tns:AddressWS" minOccurs="0" maxOccurs="1"/>
<xs:element name="otherAddresses" nillable="true" type="tns:AddressWS" minOccurs="0" maxOccurs="unbounded"/>
<xs:element name="internalRef" nillable="false" type="xs:string" minOccurs="0" maxOccurs="1"/>
</xs:sequence>
</xs:complexType>
<xs:complexType name="AddressWS">
<xs:sequence>
<xs:element name="line1" nillable="false" type="xs:string" minOccurs="0" maxOccurs="1"/>
<xs:element name="line2" nillable="false" type="xs:string" minOccurs="0" maxOccurs="1"/>
